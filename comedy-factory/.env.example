# Comedy Factory — Environment Variables
# Copy this to .env and fill in your values (or run: python setup_keys.py)

# News
NEWS_API_KEY=your_newsapi_key_here

# AI — Script generation
ANTHROPIC_API_KEY=your_anthropic_key_here

# ElevenLabs — Voice
ELEVENLABS_API_KEY=your_elevenlabs_key_here
RAVEN_VOICE_ID=your_raven_voice_id_here
JAX_VOICE_ID=your_jax_voice_id_here

# Image generation — set at least ONE of these two:
# Gemini Imagen (preferred — free 500 images/day): aistudio.google.com → Get API key
GEMINI_API_KEY=
# Leonardo.ai (fallback + --regen-characters): app.leonardo.ai → User Settings → API Access
LEONARDO_API_KEY=

# Canva — Episode thumbnails (OPTIONAL)
# Get at: canva.com → Settings → Apps & Integrations → Personal Access Tokens
CANVA_ACCESS_TOKEN=
CANVA_BRAND_TEMPLATE_ID=

# YouTube (path to OAuth client secrets JSON from Google Cloud Console)
YOUTUBE_CLIENT_SECRETS=./youtube-client-secrets.json

# TikTok
TIKTOK_ACCESS_TOKEN=

# Optional: Review gate (send script to Slack before publishing)
REVIEW_GATE_ENABLED=false
SLACK_WEBHOOK_URL=
